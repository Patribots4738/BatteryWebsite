{
	"compilerOptions": {
		"noEmit": true,
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"allowImportingTsExtensions": true,
		"target": "esnext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"paths": {
			"@shared": ["./shared"],
			"@shared/*": ["./shared/*"],
			"@api": ["./api"],
			"@api/*": ["./api/*"]
		}
	},
	"include": ["api/**/*.ts"]
}
