{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "esnext",
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"@shared": ["./shared"],
			"@shared/*": ["./shared/*"],
			"@api": ["./api"],
			"@api/*": ["./api/*"]
		},
		"tsBuildInfoFile": "./node_modules/.tmp/tsbuildinfo"
	}
}
