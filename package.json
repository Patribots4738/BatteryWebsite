{
	"name": "batterychecker",
	"private": true,
	"version": "1.0.1",
	"scripts": {
		"build": "vite build && tsc -p tsconfig.json && tsc -p ./shared/tsconfig.json",
		"lint": "eslint . --ext .ts,.tsx",
		"lint:fix": "eslint . --ext .ts,.tsx --fix",
		"prettier": "prettier --check . --ignore-unknown",
		"prettier:fix": "prettier --write . --ignore-unknown",
		"chore:lint": "pnpm run lint && pnpm run prettier",
		"chore:format": "pnpm run lint:fix && pnpm run prettier:fix",
		"docker:build": "docker build -t batterychecker-dev:latest .",
		"start": "vite build && ts-node server.ts",
		"prepare": "husky"
	},
	"lint-staged": {
		"**/*": "pnpm run prettier:fix",
		"**/*.{ts,tsx}": "pnpm run lint:fix"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@mui/icons-material": "^7.3.9",
		"@mui/material": "^7.3.9",
		"express": "^5.2.1",
		"lowdb": "^7.0.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.14.0",
		"vite-express": "^0.22.1"
	},
	"overrides": {
		"typescript": "^6.0.2",
		"ts-node": "^10.9.2"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.5"
	},
	"packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
