{
	"name": "batterychecker",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev:react": "vite --host",
		"dev:server": "nodemon --exec ts-node server/index.ts",
		"dev:all": "concurrently \"npm run dev:react\" \"npm run dev:server\"",
		"build": "vite build && tsc -p tsconfig.server.json",
		"start": "npm run build && vercel dev"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@mui/icons-material": "^7.3.9",
		"@mui/material": "^7.3.9",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"firebase": "^12.11.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"overrides": {
		"typescript": "^6.0.2",
		"ts-node": "^10.9.2"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^9.2.1",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.4.0",
		"nodemon": "^3.1.14",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vercel": "^50.37.3",
		"vite": "^8.0.1"
	}
}
